---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const page = pages.find(p => p.data.slug === 'termos-de-uso');
const { Content } = page ? await render(page) : { Content: null };
---

<Base
  title="Termos de Uso | Guia da Sanduicheira"
  description="Termos de uso do Guia da Sanduicheira. Conheça as regras de uso do nosso site."
  canonicalUrl="https://guiadasanduicheira.com.br/termos-de-uso"
>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Termos de Uso</h1>
    <div class="prose">
      {Content ? <Content /> : <p>Carregando...</p>}
    </div>
  </div>
</Base>
