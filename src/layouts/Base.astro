---
import '../styles/global.css';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  schemaType?: 'home' | 'post' | 'page' | 'contact';
  schemaFaqs?: { q: string; a: string }[];
  schemaAmazon?: { label: string; url: string }[];
  schemaBreadcrumb?: { name: string; url: string }[];
  updatedDate?: Date;
}

const {
  title,
  description,
  image = '/og-default.svg',
  canonicalUrl,
  type = 'website',
  pubDate,
  schemaType = 'page',
  schemaFaqs = [],
  schemaAmazon = [],
  schemaBreadcrumb = [],
  updatedDate,
} = Astro.props;

const siteUrl = 'https://guiadasanduicheira.com.br';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Guia da Sanduicheira" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />

    <!-- Dados estruturados JSON-LD -->
    <SchemaOrg
      type={schemaType}
      url={canonical}
      title={title}
      description={description}
      image={ogImage}
      pubDate={pubDate}
      updatedDate={updatedDate}
      faqs={schemaFaqs}
      amazonLinks={schemaAmazon}
      breadcrumb={schemaBreadcrumb}
    />

    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen">
    <header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur">
      <div class="mx-auto max-w-5xl px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="text-2xl">🥪</span>
          <span class="font-bold text-lg text-gray-900 group-hover:text-orange-600 transition-colors">
            Guia da Sanduicheira
          </span>
        </a>
        <nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/" class="hover:text-orange-600 transition-colors">Início</a>
          <a href="/melhores-sanduicheiras-eletricas-em-2025" class="hover:text-orange-600 transition-colors">Melhores</a>
          <a href="/como-escolher-sanduicheira" class="hover:text-orange-600 transition-colors">Guia</a>
          <a href="/fale-conosco" class="hover:text-orange-600 transition-colors">Contato</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-16 border-t border-gray-100 bg-gray-50 py-10">
      <div class="mx-auto max-w-5xl px-4 grid sm:grid-cols-3 gap-8 text-sm text-gray-500">
        <div>
          <p class="font-semibold text-gray-800 mb-2">🥪 Guia da Sanduicheira</p>
          <p>Avaliações honestas e independentes de sanduicheiras e grills elétricos.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-800 mb-2">Links</p>
          <ul class="space-y-1">
            <li><a href="/como-escolher-sanduicheira" class="hover:text-orange-600">Como Escolher</a></li>
            <li><a href="/melhores-sanduicheiras-eletricas-em-2025" class="hover:text-orange-600">Melhores de 2025</a></li>
            <li><a href="/diferenca-entre-sanduicheira-e-grill" class="hover:text-orange-600">Sanduicheira vs Grill</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-gray-800 mb-2">Institucional</p>
          <ul class="space-y-1">
            <li><a href="/politica-de-privacidade" class="hover:text-orange-600">Política de Privacidade</a></li>
            <li><a href="/termos-de-uso" class="hover:text-orange-600">Termos de Uso</a></li>
            <li><a href="/fale-conosco" class="hover:text-orange-600">Fale Conosco</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-8 text-center text-xs text-gray-400">
        <p>© {new Date().getFullYear()} Guia da Sanduicheira. Como Associado Amazon, ganho comissões em compras elegíveis.</p>
      </div>
    </footer>
  </body>
</html>
