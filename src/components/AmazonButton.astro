---
interface Props {
  href: string;
  label?: string;
  variant?: 'primary' | 'secondary';
}

const { href, label = 'Ver na Amazon', variant = 'primary' } = Astro.props;

const base = 'inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-all duration-200 no-underline';
const styles = variant === 'primary'
  ? `${base} bg-[#FF9900] text-gray-900 hover:bg-[#e68a00] shadow-sm hover:shadow-md`
  : `${base} border-2 border-[#FF9900] text-[#FF9900] hover:bg-[#FF9900] hover:text-gray-900`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer nofollow sponsored"
  class={styles}
  aria-label={`${label} — abre em nova aba`}
>
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
