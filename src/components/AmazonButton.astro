---
interface Props {
  href: string;
  label?: string;
  variant?: 'primary' | 'secondary';
}

const { href, label = 'Ver o Menor Preço na Amazon', variant = 'primary' } = Astro.props;

const base = 'not-prose inline-flex items-center gap-2.5 rounded-full font-bold transition-all duration-200 no-underline focus:outline-none focus:ring-2 focus:ring-[#FF9900] focus:ring-offset-2';
const styles = variant === 'primary'
  ? `${base} bg-[#FF9900] text-gray-900 hover:bg-[#e68a00] shadow-md hover:shadow-lg hover:-translate-y-0.5 px-6 py-3 text-sm`
  : `${base} border-2 border-[#FF9900] text-[#FF9900] hover:bg-[#FF9900] hover:text-gray-900 px-5 py-2.5 text-sm`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer nofollow sponsored"
  class={styles}
  aria-label={`${label} — abre em nova aba`}
>
  <!-- Ícone carrinho Amazon -->
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M19.59 15.93c-2.27 1.34-5.75 2.07-8.59 2.07-4.06 0-7.72-1.5-10.49-3.99-.22-.19-.02-.45.24-.3 2.99 1.74 6.69 2.79 10.51 2.79 2.58 0 5.41-.53 8.02-1.65.39-.17.72.26.31.08z"/>
    <path d="M20.48 14.93c-.3-.38-1.96-.18-2.71-.09-.23.03-.26-.17-.06-.31 1.33-.93 3.51-.66 3.76-.35.26.31-.07 2.5-1.31 3.54-.19.16-.37.07-.29-.14.28-.69.91-2.27.61-2.65z"/>
    <path d="M17.33 3.67C16.17 2.28 14.06 1.5 12 1.5 8.26 1.5 5.09 3.9 4.09 7.29c-.13.44.42.65.67.27C5.86 5.4 8.63 3.5 12 3.5c1.63 0 3.47.54 4.72 1.84.14.15.42.05.33-.17l-.08-.2c-.18-.44-.04-.95.36-1.3z"/>
    <path d="M6 8a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1H6zm6 7a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
  </svg>
  {label}
  <!-- Seta -->
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
  </svg>
</a>
