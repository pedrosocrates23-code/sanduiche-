---
/**
 * Wrapper sobre <Picture> do astro:assets.
 * Serve AVIF (primário) e WebP (fallback). Nunca JPEG/PNG no browser.
 * Para imagens locais em src/assets/images/ faz a conversão em build time.
 * Para imagens não encontradas, cai para <img> estático em /images/.
 */
import { Picture } from 'astro:assets';

interface Props {
  src: string;               // nome do arquivo: "imagem.jpg"
  alt: string;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  widths = [400, 768, 1200],
  sizes = '(max-width: 768px) 100vw, 768px',
  class: className,
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

// Pré-carrega todos os módulos de imagem locais em build time
const localImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpg,jpeg,png,webp}'
);

const key = `/src/assets/images/${src}`;
const imageLoader = localImages[key];
const imageData = imageLoader ? (await imageLoader()).default : null;
---

{imageData ? (
  <Picture
    src={imageData}
    alt={alt}
    widths={widths}
    formats={['avif', 'webp']}
    sizes={sizes}
    class={className}
    loading={loading}
    fetchpriority={fetchpriority}
  />
) : (
  /* Fallback para imagem estática quando não encontrada em src/assets */
  <picture>
    <source
      type="image/webp"
      srcset={`/images/${src.replace(/\.(jpg|jpeg|png)$/i, '.webp')}`}
    />
    <img
      src={`/images/${src}`}
      alt={alt}
      class={className}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  </picture>
)}
