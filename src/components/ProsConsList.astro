---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="not-prose my-8 grid sm:grid-cols-2 gap-4">

  <!-- PRÓS — verde -->
  <div class="rounded-xl border border-green-200 bg-green-50 overflow-hidden">
    <div class="flex items-center gap-2 bg-green-600 px-4 py-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      <span class="font-bold text-white text-base">Prós</span>
    </div>
    <ul class="divide-y divide-green-100">
      {pros.map(item => (
        <li class="flex items-start gap-3 px-4 py-2.5 text-sm text-green-900">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- CONTRAS — vermelho -->
  <div class="rounded-xl border border-red-200 bg-red-50 overflow-hidden">
    <div class="flex items-center gap-2 bg-red-600 px-4 py-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
      <span class="font-bold text-white text-base">Contras</span>
    </div>
    <ul class="divide-y divide-red-100">
      {cons.map(item => (
        <li class="flex items-start gap-3 px-4 py-2.5 text-sm text-red-900">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>

</div>
